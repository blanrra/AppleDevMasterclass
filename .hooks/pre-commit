#!/bin/bash
# Pre-commit hook: verifica que los archivos Swift compilan
# Instalar: cp .hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

SWIFT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$')

if [ -z "$SWIFT_FILES" ]; then
    exit 0
fi

echo "Verificando archivos Swift..."
FAILED=0

for file in $SWIFT_FILES; do
    if swiftc -typecheck "$file" 2>/dev/null; then
        echo "  OK: $file"
    else
        echo "  FALLO: $file"
        FAILED=$((FAILED + 1))
    fi
done

if [ $FAILED -gt 0 ]; then
    echo ""
    echo "$FAILED archivo(s) no compilan. Corrige antes de hacer commit."
    exit 1
fi

echo "Todos los archivos Swift compilan correctamente."
exit 0
